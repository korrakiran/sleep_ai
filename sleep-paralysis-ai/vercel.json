{
  "version": 2,
  "rewrites": [
    { "source": "/api/(.*)", "destination": "/backend/run.py" },
    { "source": "/", "destination": "/frontend/index.html" },
    { "source": "/(.*)", "destination": "/frontend/$1" }
  ],
  "functions": {
    "backend/run.py": {
      "runtime": "vercel-python@0.1.1"
    }
  }
}
