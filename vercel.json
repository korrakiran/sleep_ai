{
  "version": 2,
  "builds": [
    {
      "src": "api/index.py",
      "use": "@vercel/python"
    },
    {
      "src": "sleep-paralysis-ai/frontend/**",
      "use": "@vercel/static"
    }
  ],
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "api/index.py"
    },
    {
      "source": "/",
      "destination": "sleep-paralysis-ai/frontend/index.html"
    },
    {
      "source": "/(.*)",
      "destination": "sleep-paralysis-ai/frontend/$1"
    }
  ]
}
