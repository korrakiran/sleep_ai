{
  "version": 2,
  "rewrites": [
    { "source": "/api/(.*)", "destination": "/sleep-paralysis-ai/backend/run.py" },
    { "source": "/", "destination": "/sleep-paralysis-ai/frontend/index.html" },
    { "source": "/(.*)", "destination": "/sleep-paralysis-ai/frontend/$1" }
  ],
  "functions": {
    "sleep-paralysis-ai/backend/run.py": {
      "maxDuration": 15
    }
  }
}
